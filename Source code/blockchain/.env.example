# Blockchain Environment Variables
# Copy file này thành .env và điền giá trị thật

# Private key của ví deployer (KHÔNG commit lên git!)
PRIVATE_KEY=your_wallet_private_key_here

# RPC URLs (lấy miễn phí từ Alchemy hoặc Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# API keys để verify contract trên explorer
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
